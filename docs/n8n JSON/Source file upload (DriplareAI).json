        "path": "driplare-ingest",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "8c0d75bf-ae12-4a0a-aaa6-441f889cadce",
      "name": "Ingest Webhook1",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -1040,
        1216
      ],
      "webhookId": "driplare-ingest"
    },
    {
      "parameters": {
        "jsCode": "let texts = [];\nconst items = $input.all();\n\nfor (const item of items) {\n  const json = item.json;\n  let text = '';\n  \n  if (json.text) {\n    text = json.text;\n  }\n  else if (json.data) {\n    if (Array.isArray(json.data)) {\n      text = json.data.map(page => page.markdown || page.content || '').join('\\n\\n');\n    } else {\n      text = json.data.markdown || json.data.content || '';\n    }\n  }\n  else if (json.content) {\n    text = json.content;\n  }\n  else {\n    text = JSON.stringify(json);\n  }\n  \n  if (text) {\n    texts.push(text);\n  }\n}\n\nlet combinedText = texts.join('\\n\\n');\n\n// Clean text: remove null characters (\\u0000) which break PostgreSQL protocol\ncombinedText = combinedText.replace(/\\u0000/g, '');\nconst cleanName = ($('Generate IDs').item.json.name || '').replace(/\\u0000/g, '');\n\nreturn [{\n  json: {\n    fullText: combinedText,\n    charCount: combinedText.length,\n    sourceId: $('Generate IDs').item.json.sourceId,\n    chatbotId: $('Generate IDs').item.json.chatbotId,\n    type: $('Generate IDs').item.json.type,\n    name: cleanName\n  }\n}];"
      },
