    {
      "parameters": {
        "jsCode": "// Normalize Text1 নোড থেকে ডাটা নেওয়া হচ্ছে\nconst item = $('Normalize Text1').item.json; \n\n// LangChain documentDefaultDataLoader সবসময় 'pageContent' field খোঁজে\n// তাই fullText কে pageContent নামে পাস করতে হবে, না হলে embedding empty হয়\nreturn [{\n    json: {\n        pageContent: item.fullText,\n        sourceId: item.sourceId,\n        chatbotId: item.chatbotId\n    }\n}];\n"
      },
      "id": "894eb809-c463-4256-8ee8-d136c19e8e4d",
      "name": "Prep for Vector Store",
