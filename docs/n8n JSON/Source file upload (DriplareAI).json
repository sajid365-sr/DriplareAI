{
  "name": "Source file upload (DriplareAI)",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst binary = $input.first().binary;\nconst id = body.sourceId || ('src_' + Math.random().toString(36).substr(2, 9) + Date.now().toString(36));\n\n// Binary থেকে file extension বের করা (Switch node এ সহজে ম্যাচ করার জন্য)\nlet fileExtension = '';\nif (binary && binary.file) {\n  fileExtension = (binary.file.fileExtension || '').toLowerCase();\n  if (!fileExtension && binary.file.fileName) {\n    const parts = binary.file.fileName.split('.');\n    fileExtension = parts.length > 1 ? parts[parts.length - 1].toLowerCase() : '';\n  }\n}\n\nreturn [{\n  json: {\n    sourceId: id,\n    chatbotId: body.chatbotId,\n    userId: body.userId,\n    type: body.type,\n    name: body.name || 'Untitled Source',\n    url: body.url,\n    fileExtension: fileExtension\n  },\n  binary: binary\n}];"
      },
      "id": "34c7e244-7900-4310-859d-63f482a21444",
      "name": "Generate IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -816,
        1216
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"Source\" (\"id\", \"sourceId\", \"chatbotId\", \"type\", \"name\", \"content\", \"charCount\", \"createdAt\")\nVALUES (\n  '{{ $json.sourceId }}', \n  '{{ $json.sourceId }}', \n  '{{ $json.chatbotId }}', \n  '{{ $json.type }}', \n  '{{ $json.name.replace(/'/g, \"''\") }}', \n  '{{ $json.fullText.replace(/'/g, \"''\") }}', \n  {{ $json.charCount }}, \n  NOW()\n);\n",
        "options": {}
      },
      "id": "aecf58f4-fa99-48e1-87c8-19b455ba4221",
