      "parameters": {
        "jsCode": "const raw = $('Anylize').item.json.output ?? '{}';\n\nlet parsed;\n\ntry {\n  parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch (error) {\n  parsed = {\n    sentiment: null,\n    topic: null,\n    rawOutput: raw,\n  };\n}\n\nreturn [\n  {\n    json: {\n      sentiment: parsed.sentiment ?? null,\n      topic: parsed.topic ?? null,\n      rawAnalysis: parsed,\n    },\n  },\n];\n"
