    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"ChatSession\" (\"id\", \"chatbotId\", \"sessionId\", \"platform\", \"guestName\", \"profilePhoto\", \"isActive\", \"createdAt\", \"updatedAt\")\nVALUES (\n  gen_random_uuid()::text, \n  '{{ $('Extract Fields').item.json.chatbotId }}', \n  '{{ $('Extract Fields').item.json.sessionId }}', \n  'facebook', \n  '{{ $('Extract Fields').item.json.userName }}', \n  NULLIF('{{ $('Extract Fields').item.json.profilePhoto }}', ''), \n  true, \n  NOW(), \n  NOW()\n)\nON CONFLICT (\"chatbotId\", \"sessionId\") \nDO UPDATE SET \n  \"updatedAt\" = NOW(), \n  \"guestName\" = '{{ $('Extract Fields').item.json.userName }}',\n  \"profilePhoto\" = NULLIF('{{ $('Extract Fields').item.json.profilePhoto }}', '');\n\nINSERT INTO \"ChatMessage\" (\"id\", \"chatbotId\", \"userId\", \"sessionId\", \"role\", \"content\", \"timestamp\")\nVALUES \n  (gen_random_uuid()::text, '{{ $('Extract Fields').item.json.chatbotId }}', '{{ $('Extract Fields').item.json.userId }}', '{{ $('Extract Fields').item.json.sessionId }}', 'user', '{{ $('Extract Fields').item.json.messageText }}', NOW() - INTERVAL '1 second'),\n  (gen_random_uuid()::text, '{{ $('Extract Fields').item.json.chatbotId }}', '{{ $('Extract Fields').item.json.userId }}', '{{ $('Extract Fields').item.json.sessionId }}', 'assistant', '{{ $('Brain').item.json.output }}', NOW());\n\nUPDATE \"User\"\nSET \"messagesUsedThisCycle\" = \"messagesUsedThisCycle\" + 1\nWHERE \"userId\" = '{{ $('Extract Fields').item.json.userId }}';\n",
        "options": {}
