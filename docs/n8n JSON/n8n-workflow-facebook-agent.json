    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  c.\"chatbotId\",\n  c.\"userId\",\n  c.\"provider\",\n  c.\"model\",\n  c.\"systemPrompt\",\n  c.\"temperature\",\n  c.\"maxTokens\",\n  u.\"includedMessages\" AS \"totalMessagesLimit\",\n  u.\"messagesUsedThisCycle\" AS \"messagesUsed\",\n  GREATEST(0, u.\"includedMessages\" - u.\"messagesUsedThisCycle\") AS \"messagesRemaining\",\n  i.\"connected\",\n  i.config->>'pageToken' AS \"pageToken\",\n  i.config->>'pageId' AS \"pageId\",\n  i.config->>'pageName' AS \"pageName\",\n  ec.\"productSheetId\",\n  ec.\"productSheetName\",\n  ec.\"orderSheetId\",\n  ec.\"orderSheetName\",\n  ec.\"steadfastEnabled\",\n  ec.\"steadfastApiKey\",\n  ec.\"steadfastSecretKey\",\n  ec.\"pathaoEnabled\",\n  ec.\"pathaoClientId\",\n  ec.\"pathaoClientSecret\",\n  ec.\"pathaoMerchantId\"\nFROM \"Integration\" i\nJOIN \"Chatbot\" c ON i.\"chatbotId\" = c.\"chatbotId\"\nJOIN \"User\" u ON c.\"userId\" = u.\"userId\"\nLEFT JOIN \"EcommerceConfig\" ec ON ec.\"chatbotId\" = c.\"chatbotId\"\nWHERE i.platform = 'facebook'\n  AND i.\"connected\" = true\n  AND (u.\"includedMessages\" - u.\"messagesUsedThisCycle\") > 0\n  AND i.config->>'pageId' = '{{ $json.body.entry[0].messaging[0].recipient.id || $json.body.entry[0].id }}';\n",
        "options": {}
      },
      "id": "6fe68ef0-be4c-47fc-aedc-c49db5d27874",
      "name": "Fetch Bot Config",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        -512,
        1248
      ],
      "credentials": {
        "postgres": {
          "id": "3Aiu7UNMUMPB6aNu",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const config = $('Fetch Bot Config').item.json;\nconst meta = $('Get Facebook Message').item.json.body;\n\nif (!meta?.entry?.[0]?.messaging?.[0]) return [];\n\nconst messaging = meta.entry[0].messaging[0];\nconst senderId = messaging.sender.id;\n\n// Ignore echo messages\nif (messaging.message?.is_echo) return [];\n\n// Fetch User Profile from Meta Graph API using fetch\nlet userName = 'Customer';\nlet profilePhoto = null;\ntry {\n  const pageToken = config.pageToken;\n  const profileRes = await fetch(`https://graph.facebook.com/v20.0/${senderId}?fields=first_name,last_name,profile_pic&access_token=${pageToken}`);\n  const profileData = await profileRes.json();\n  if (profileData) {\n    if (profileData.first_name) {\n      userName = `${profileData.first_name} ${profileData.last_name || ''}`.trim();\n    }\n    if (profileData.profile_pic) {\n      profilePhoto = profileData.profile_pic;\n    }\n  }\n} catch (e) {\n  // Safe fallback\n}\n\n// Detect input type\nconst attachmentType = messaging.message?.attachments?.[0]?.type;\nlet messageText = '';\nlet messageType = 'text';\n\nif (!attachmentType && messaging.message?.text) {\n  messageText = messaging.message.text;\n  messageType = 'text';\n} else if (attachmentType === 'image') {\n  messageText = $json.imageDescription || 'User sent an image.';\n  messageType = 'image';\n} else if (attachmentType === 'audio') {\n  messageText = $json.text || $json.transcription || 'User sent a voice message.';\n  messageType = 'audio';\n} else {\n  return [];\n}\n\n// Append order handling instruction to system prompt\nconst orderInstruction = `\\n\\n---\\nWhen a customer confirms their order by providing name, phone, and address, respond ONLY with this JSON (no other text):\\n{\"action\":\"create_order\",\"recipient_name\":\"<name>\",\"recipient_phone\":\"<phone>\",\"recipient_address\":\"<address>\",\"cod_amount\":\"<total BDT>\",\"product_name\":\"<product name>\"}\\nFor all other conversations, respond normally.`;\n\nreturn [{\n  json: {\n    ...config,\n    senderId,\n    sessionId: `fb_${senderId}`,\n    messageText,\n    messageType,\n    userName,\n    profilePhoto,\n    systemPrompt: config.systemPrompt + orderInstruction\n  }\n}];\n"
      },
