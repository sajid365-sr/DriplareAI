    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  c.\"chatbotId\",\n  c.\"userId\",\n  c.\"model\",\n  c.\"systemPrompt\",\n  c.\"temperature\",\n  c.\"maxTokens\",\n  GREATEST(0, u.\"includedMessages\" - u.\"messagesUsedThisCycle\") AS \"messagesRemaining\",\n  i.\"integrationId\",\n  i.config->>'pageToken' AS \"pageToken\",\n  i.config->>'pageId' AS \"pageId\",\n  i.config->>'pageName' AS \"pageName\",\n  i.config->'commentReply' AS \"commentReplyConfig\"\nFROM \"Integration\" i\nJOIN \"Chatbot\" c ON i.\"chatbotId\" = c.\"chatbotId\"\nJOIN \"User\" u ON c.\"userId\" = u.\"userId\"\nWHERE i.platform = 'facebook'\n  AND i.\"connected\" = true\n  AND i.config->>'pageId' = '{{ $('Get Facebook Message').item.json.body.entry[0].id }}';",
        "options": {}
      },
      "id": "fetch-comment-config-node",
      "name": "Fetch Comment Config",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [0, 1600],
      "credentials": { "postgres": { "id": "3Aiu7UNMUMPB6aNu", "name": "Postgres account" } }
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('Fetch Comment Config').item.json;\nconst body = $('Get Facebook Message').item.json.body;\n\n// Parse commentReply config from DB\nlet crCfg = {};\ntry {\n  crCfg = typeof cfg.commentReplyConfig === 'string'\n    ? JSON.parse(cfg.commentReplyConfig)\n    : (cfg.commentReplyConfig || {});\n} catch(e) {}\n\n// Exit if disabled or no quota\nif (!crCfg.enabled) return [];\nif ((cfg.messagesRemaining || 0) <= 0) return [];\n\nconst change = body.entry?.[0]?.changes?.[0]?.value;\nif (!change || change.item !== 'comment' || change.verb !== 'add') return [];\n\nconst commentId = change.comment_id;\nconst fromId = change.from?.id;\nconst fromName = change.from?.name || 'Customer';\nconst commentText = (change.message || '').trim();\nconst pageId = cfg.pageId;\n\n// Skip bot's own comments (prevent infinite loop)\nif (fromId === pageId) return [];\nif (!commentText) return [];\n\nreturn [{\n  json: {\n    ...cfg,\n    commentId,\n    fromId,\n    fromName,\n    commentText,\n    sessionId: `fb_comment_${fromId}`,\n    mode: crCfg.mode || 'ai',\n    fixedMessage: crCfg.fixedMessage || '',\n    sendPrivateDM: crCfg.sendPrivateDM || false\n  }\n}];"
      },
