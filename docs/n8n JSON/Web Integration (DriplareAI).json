    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  '{{ $json.body.sessionId }}' as \"sessionId\",\n  '{{ $json.body.userId }}' as \"userId\",\n  c.\"chatbotId\", \n  c.\"provider\", \n  c.\"model\", \n  c.\"systemPrompt\", \n  c.\"temperature\", \n  c.\"maxTokens\", \n  u.\"includedMessages\", \n  u.\"messagesUsedThisCycle\"\nFROM \"Chatbot\" c\nJOIN \"User\" u ON c.\"userId\" = u.\"userId\"\nWHERE c.\"chatbotId\" = '{{ $json.body.chatbotId }}';\n",
        "options": {}
      },
      "id": "0d1042de-5218-457e-9f5e-4d54779c665b",
