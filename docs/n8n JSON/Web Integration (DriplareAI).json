    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- ১. চ্যাট সেশন তৈরি বা আপডেট করা\nINSERT INTO \"ChatSession\" (\"id\", \"chatbotId\", \"sessionId\", \"platform\", \"guestName\", \"isActive\", \"createdAt\", \"updatedAt\")\nVALUES (\n  gen_random_uuid()::text, \n  '{{ $node[\"Webhook (Web)\"].json.body.chatbotId }}', \n  '{{ $node[\"Webhook (Web)\"].json.body.sessionId }}', \n  'web', \n  'Web Test User', \n  true, \n  NOW(), \n  NOW()\n)\nON CONFLICT (\"chatbotId\", \"sessionId\") \nDO UPDATE SET \n  \"updatedAt\" = NOW();\n\n-- ২. ইউজারের মেসেজ সেভ করা\nINSERT INTO \"ChatMessage\" (\"id\", \"chatbotId\", \"userId\", \"sessionId\", \"role\", \"content\", \"timestamp\")\nVALUES (\n  gen_random_uuid()::text, \n  '{{ $node[\"Webhook (Web)\"].json.body.chatbotId }}', \n  '{{ $node[\"Webhook (Web)\"].json.body.userId }}', \n  '{{ $node[\"Webhook (Web)\"].json.body.sessionId }}', \n  'user', \n  '{{ $node[\"Webhook (Web)\"].json.body.chatInput.replace(/'/g, \"''\") }}', \n  NOW() - INTERVAL '1 second'\n);\n\n-- ৩. AI এর উত্তর সেভ করা\nINSERT INTO \"ChatMessage\" (\"id\", \"chatbotId\", \"userId\", \"sessionId\", \"role\", \"content\", \"timestamp\")\nVALUES (\n  gen_random_uuid()::text, \n  '{{ $node[\"Webhook (Web)\"].json.body.chatbotId }}', \n  '{{ $node[\"Webhook (Web)\"].json.body.userId }}', \n  '{{ $node[\"Webhook (Web)\"].json.body.sessionId }}', \n  'assistant', \n  '{{ $node[\"Web Brain\"].json.output.replace(/'/g, \"''\") }}', \n  NOW()\n);\n\n-- ৪. ইউজারের মেসেজ কোটা আপডেট করা (pointsUsed এর বদলে messagesUsedThisCycle)\nUPDATE \"User\" \nSET \"messagesUsedThisCycle\" = \"messagesUsedThisCycle\" + 2 \nWHERE \"userId\" = '{{ $node[\"Webhook (Web)\"].json.body.userId }}';\n",
        "options": {}
      },
